# ── SafiBase Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — add it to .gitignore.

# ── Form Backend ─────────────────────────────────────────────────────────────
# Choose one: formspree | airtable | webhook
REACT_APP_FORM_BACKEND=formspree

# ── Option 1: Formspree (easiest — free tier available) ──────────────────────
# Sign up at https://formspree.io → create a form → copy the ID from the URL
# e.g. https://formspree.io/f/xpwzabcd → ID is "xpwzabcd"
REACT_APP_FORMSPREE_ID=your_formspree_form_id

# ── Option 2: Airtable ───────────────────────────────────────────────────────
# 1. Create a base at https://airtable.com with these fields:
#    Name | Company | Email | Phone | Monthly Consultations | Biggest Bottleneck | Submitted At
# 2. Generate a Personal Access Token at https://airtable.com/create/tokens
#    Scopes needed: data.records:write
# 3. Find your Base ID in the API docs: https://airtable.com/developers/web/api/introduction
REACT_APP_AIRTABLE_API_KEY=your_airtable_personal_access_token
REACT_APP_AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
REACT_APP_AIRTABLE_TABLE_NAME=Leads

# ── Option 3: Make.com / Zapier / n8n Webhook ────────────────────────────────
# Create a webhook trigger in Make.com, Zapier, or n8n and paste the URL here.
# The payload sent will be:
# { name, company, email, phone, consultations, bottleneck, source, timestamp }
REACT_APP_WEBHOOK_URL=https://hook.make.com/your_webhook_id

# ── GitHub Pages (if using a custom repo path) ───────────────────────────────
# If deploying to https://yourusername.github.io/safibase/
# uncomment and set:
# PUBLIC_URL=/safibase
